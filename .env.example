# ── Database ────────────────────────────────────────────────────────────────
# MySQL (Hostinger production):
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME"
# SQLite for local dev only (change provider in schema.prisma back to "sqlite"):
# DATABASE_URL="file:./dev.db"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-real-32-char-secret"
AUTH_URL="https://yourdomain.com"

# ── Google OAuth (optional) ───────────────────────────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get free key at https://resend.com — powers the /api/contact form
RESEND_API_KEY=""
CONTACT_EMAIL="info@digitaltriangle.in"

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
