generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// AUTHENTICATION & USERS
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  avatar    String?
  bio       String?
  role      String   @default("EDITOR") // SUPER_ADMIN | ADMIN | EDITOR | VIEWER
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts Account[]
  sessions Session[]
  posts    Post[]    @relation("PostAuthor")
  comments Comment[] @relation("CommentAuthor")

  @@index([role])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// CMS - BLOG & CONTENT
// ============================================================

model Post {
  id       String  @id @default(cuid())
  slug     String  @unique
  title    String
  excerpt  String?
  content  String // Rich text as HTML/JSON
  status   String  @default("DRAFT") // DRAFT | SCHEDULED | PUBLISHED | ARCHIVED
  featured Boolean @default(false)

  // SEO fields
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?
  canonical       String?

  // Relations
  authorId String
  author   User      @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  tags     Tag[]     @relation("PostTags")
  comments Comment[] @relation("PostComments")

  // Timestamps
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([slug])
  @@index([publishedAt])
}

model Tag {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String  @unique
  description String?
  color       String? // Hex color for UI

  posts Post[] @relation("PostTags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id      String @id @default(cuid())
  content String
  status  String @default("PENDING") // PENDING | APPROVED | SPAM | DELETED

  postId String
  post   Post   @relation("PostComments", fields: [postId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([status])
}

// ============================================================
// STATIC PAGES
// ============================================================

model Page {
  id      String @id @default(cuid())
  slug    String @unique
  title   String
  content String // Rich text as HTML/JSON

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}

// ============================================================
// MEDIA & FILES
// ============================================================

model Media {
  id       String  @id @default(cuid())
  filename String
  url      String  @unique
  alt      String?
  size     Int // File size in bytes
  width    Int? // Image dimensions
  height   Int?
  mimeType String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mimeType])
}

// ============================================================
// NEWSLETTER & SUBSCRIPTIONS
// ============================================================

model Subscriber {
  id     String @id @default(cuid())
  email  String @unique
  status String @default("ACTIVE") // ACTIVE | UNSUBSCRIBED | BOUNCED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ============================================================
// ANALYTICS & TRACKING
// ============================================================

model PageView {
  id        String  @id @default(cuid())
  path      String
  referer   String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

// ============================================================
// SETTINGS & CONFIGURATION
// ============================================================

model SiteSettings {
  id              String  @id @default(cuid())
  siteTitle       String  @default("Digital Triangle")
  siteDescription String?
  logo            String?
  favicon         String?
  primaryColor    String?
  secondaryColor  String?
  accentColor     String?
  contactEmail    String?
  socialLinks     String? // JSON stringified { twitter, linkedin, etc }

  updatedAt DateTime @updatedAt
}

// ============================================================
// LEADS / FORM SUBMISSIONS
// ============================================================

model Lead {
  id       String  @id @default(cuid())
  type     String  @default("CONTACT") // CONTACT | CONSULTATION | AUDIT
  name     String
  email    String
  phone    String?
  company  String?
  website  String?
  budget   String?
  services String? // comma-separated list
  goals    String? // comma-separated list (consultation)
  slot     String? // preferred time slot (consultation)
  message  String? // message / challenge text
  status   String  @default("NEW") // NEW | CONTACTED | QUALIFIED | CLOSED | SPAM
  source   String? // page path the lead came from

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}
